# MyQRLWallet desktop: example environment.
# Copy to .env (gitignored) and adjust. RPC values are read by the main process
# at startup (src/main/config.ts) and also derive the CSP connect-src allowlist,
# so only origins listed here can be reached by the renderer.

# ---------------------------------------------------------------------------
# Runtime (main process)
# ---------------------------------------------------------------------------

# Primary JSON-RPC endpoint (QRL v2, qrl_* namespace).
# Default: the testnet-v2 node documented in the workspace CLAUDE.md.
QRL_RPC_URL=https://qrlwallet.com/api/qrl-rpc/testnet

# Optional secondary endpoint for read-only failover (foundation public RPC).
# Its origin is also added to the CSP connect-src allowlist.
QRL_RPC_URL_SECONDARY=http://209.250.255.226:8545

# Fallback chain id used only if qrl_chainId cannot be read. testnet-v2 = 1337.
QRL_CHAIN_ID=1337

# Idle timeout in milliseconds before the signer auto-locks and zeroizes the
# in-memory session. Default is 300000 (5 minutes).
QRL_AUTOLOCK_MS=300000

# Allow the cross-platform safeStorage KEK vault (OS-key wrap, NO Touch ID /
# passcode prompt, readable by other code running as the same user). Set to
# "true" to permit it; leave unset/false to require the hardware-backed
# (macOS Keychain user-presence) vault. See src/keyvault/safeStorageVault.ts.
QRL_ALLOW_SAFESTORAGE=false

# ---------------------------------------------------------------------------
# macOS code-signing + notarization (afterSign hook: scripts/notarize.cjs)
# Uses an App Store Connect API key (.p8). Never commit these values.
# ---------------------------------------------------------------------------

# Absolute path to the App Store Connect API key file (AuthKey_XXXX.p8).
APPLE_API_KEY=
# The key id (the XXXX in the filename).
APPLE_API_KEY_ID=
# The issuer id (UUID) from App Store Connect.
APPLE_API_ISSUER=
# Apple Developer team id, used for the Developer ID signing identity.
APPLE_TEAM_ID=

# ---------------------------------------------------------------------------
# Windows code-signing (electron-builder win.signtoolOptions)
# ---------------------------------------------------------------------------

# Path to the code-signing certificate (.pfx) or a base64 of it.
WIN_CSC_LINK=
# Password for the certificate above.
WIN_CSC_KEY_PASSWORD=

# ---------------------------------------------------------------------------
# Detached PGP signing of build artifacts (afterAllArtifactBuild hook:
# scripts/pgp-sign.cjs)
# ---------------------------------------------------------------------------

# GPG key id (long id or fingerprint) used to produce .asc signatures.
GPG_KEY_ID=

# ---------------------------------------------------------------------------
# Optional: pin the macOS signing identity by name. electron-builder otherwise
# auto-discovers it from the keychain. Example: "Developer ID Application: ...".
# ---------------------------------------------------------------------------
CSC_NAME=
